# -----------------------------------------------------------------------------
# WiFi credentials for ESPectre.
#
# 1. Copy this file and rename the copy to:  secrets.yaml
# 2. Fill in your 2.4 GHz WiFi name and password below.
#
# IMPORTANT: ESP32 only supports 2.4 GHz WiFi (NOT 5 GHz). If your router shows
# one combined network, that's fine - it will connect on 2.4 GHz.
# -----------------------------------------------------------------------------

wifi_ssid: "YourWiFiName"
wifi_password: "YourWiFiPassword"

# Optional: lock the ESP32 to one specific access point (useful on mesh WiFi).
# Find the BSSID (router MAC) and uncomment the line below + the bssid line in
# the yaml config.
# wifi_bssid: "AA:BB:CC:DD:EE:FF"
